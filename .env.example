# 이 파일은 참고용입니다.
# 실제 값은 GitHub Secrets 또는 Vercel Environment Variables에 등록하세요.
# 이 파일에 진짜 비밀번호, API Key, GitHub Token을 적어서 GitHub에 올리면 안 됩니다.

# GitHub Actions에서 호텔 봇 실행용
SERPAPI_API_KEY=여기에_SerpAPI_API_Key
GMAIL_USER=보내는_Gmail_주소
GMAIL_APP_PASSWORD=Gmail_앱_비밀번호
TO_EMAIL=받는_이메일_주소_선택사항_config_json_to_email_우선

# Vercel 관리자 화면용
ADMIN_PASSWORD=관리자_화면_접속_비밀번호
GITHUB_TOKEN=GitHub_Personal_Access_Token
GITHUB_OWNER=lemonsnack-rgb
GITHUB_REPO=hotel_bot
GITHUB_BRANCH=main
GITHUB_WORKFLOW_FILE=daily.yml
