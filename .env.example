GITHUB_REPO=hotel_bot
GITHUB_BRANCH=main
GITHUB_WORKFLOW_FILE=daily.yml

# Supabase
DATA_URL=https://your-project-id.supabase.co
DATA_KEY=your_supabase_service_role_key
